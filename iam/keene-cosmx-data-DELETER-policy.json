{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeleteObjectsInKeeneCosmxData",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::keene-cosmx-data/*"
    },
    {
      "Sid": "ListForDeletion",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:ListBucketVersions",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::keene-cosmx-data"
    }
  ]
}
