# EC2 analytics instance configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ── IAM setup (ask your admin to run these) ─────────────────────────────
#
# 1. Operator permissions — attach to the IAM user who runs these scripts:
#
#      aws iam put-user-policy \
#        --user-name <IAM_USER> \
#        --policy-name ec2-analytics-operator \
#        --policy-document file://ec2/ec2-operator-policy.json
#
# 2. Instance profile role — create (or update) the role the EC2 assumes:
#
#    a) Trust relationship (lets EC2 assume the role):
#
#      aws iam create-role \
#        --role-name <ROLE_NAME> \
#        --assume-role-policy-document file://ec2/instance-profile-trust-policy.json
#
#    b) Permissions (SSM agent + S3 read — edit the bucket ARN first):
#
#      aws iam put-role-policy \
#        --role-name <ROLE_NAME> \
#        --policy-name ec2-instance-permissions \
#        --policy-document file://ec2/instance-profile-permissions-policy.json
#
#    c) Create the instance profile and attach the role:
#
#      aws iam create-instance-profile --instance-profile-name <ROLE_NAME>
#      aws iam add-role-to-instance-profile \
#        --instance-profile-name <ROLE_NAME> --role-name <ROLE_NAME>

AWS_REGION=us-west-2

# Networking (same VPC as Fargate, private subnets)
EC2_SUBNET=subnet-xxxxx
EC2_SECURITY_GROUP=sg-xxxxx

# SSH key pair and IAM instance profile
EC2_KEY_PAIR=your-key-pair-name
EC2_INSTANCE_PROFILE=your-instance-profile-name

# Base Ubuntu 24.04 AMI (region-specific)
UBUNTU_BASE_AMI=ami-xxxxx

# Custom AMI (populated after running create_ami.py)
EC2_AMI_ID=ami-xxxxx

# DCV login password for the ubuntu user (optional — set manually via SSM if omitted)
DCV_PASSWORD=
